import requests

def get_locations():
    params = {
        "grid": "ERCOT"
    }

    r = requests.get(
        "http://localhost:8000/locations",
        params=params,
        timeout=30
    )

    r.raise_for_status()
    print(f"Loaded {len(r.json())} rows")
    return r.json()

def put_location(node_name: str):
    params = {
        "grid": "ERCOT",
        "node_name": node_name,
        "node_type": "ELECTRICAL_BUS",
    }


    r = requests.post(
        "http://localhost:8000/locations",
        params=params,
        timeout=30
    )

    r.raise_for_status()
    print(r.json())
    return r.json()


get_locations()
